{
  // Window
  "window.title": "${appName}",
  "window.autoDetectColorScheme": true,
  "window.restoreFullscreen": true,
  "window.zoomLevel": 0,
  // Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  // Files
  "files.simpleDialog.enable": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "files.enableTrash": true,
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/node_modules": true
  },
  // Workbench
  "workbench.startupEditor": "newUntitledFile",
  "workbench.commandPalette.history": 0,
  "workbench.list.smoothScrolling": true,
  "workbench.editor.restoreViewState": false,
  "workbench.settings.editor": "json",
  "breadcrumbs.enabled": false,
  // Theme
  "workbench.preferredLightColorTheme": "GitHub Dark",
  "workbench.preferredDarkColorTheme": "GitHub Dark",
  "workbench.colorTheme": "GitHub Dark",
  // Zen
  "zenMode.centerLayout": false,
  // Neovim
  "vscode-neovim.neovimExecutablePaths.darwin": "/usr/local/bin/nvim",
  "vscode-neovim.mouseSelectionStartVisualMode": true,
  "editor.lineNumbers": "relative",
  // Editor
  "editor.fontFamily": "JetBrains Mono, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.wrappingStrategy": "advanced",
  "editor.wrappingIndent": "deepIndent",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.tabCompletion": "on",
  "editor.acceptSuggestionOnEnter": "smart",
  // Suggestions
  "editor.wordBasedSuggestions": false,
  "editor.quickSuggestionsDelay": 0,
  "editor.snippetSuggestions": "top",
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  // Visual
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": true,
  "editor.selectionHighlight": false,
  "editor.occurrencesHighlight": false,
  "editor.cursorSmoothCaretAnimation": true,
  "editor.scrollBeyondLastLine": false,
  "editor.smoothScrolling": true,
  "editor.rulers": [
    {
      "column": 80,
      "color": "#5698FD44"
    },
    {
      "column": 120,
      "color": "#5698FD44"
    }
  ],
  // source
  "editor.codeActionsOnSave": {
    "source.organizeImports": true,
    "source.fixAll": true
  },
  // Output
  "[Log]": {
    "editor.fontSize": 14,
  },
  // Debug
  "debug.console.fontFamily": "JetBrains Mono, monospace",
  "debug.console.fontSize": 14,
  "debug.inlineValues": true,
  // Terminal
  "terminal.integrated.fontFamily": "JetBrains Mono, monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.showExitAlert": false,
  // Git
  "git.allowForcePush": true,
  "git.enableSmartCommit": true,
  "git.postCommitCommand": "sync",
  "git.confirmSync": false,
  "git.autofetch": true,
  // C
  "C_Cpp.clang_format_fallbackStyle": "Visual Studio",
  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.default.cStandard": "c17",
  // Java
  "java.referencesCodeLens.enabled": true,
  "java.implementationsCodeLens.enabled": true,
  "java.codeGeneration.generateComments": true,
  "java.completion.guessMethodArguments": true,
  "java.refactor.renameFromFileExplorer": "autoApply",
  // Python
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "/usr/local/bin/python3",
  "python.pythonPath": "/usr/local/bin/python3",
  "python.formatting.provider": "autopep8",
  "python.analysis.diagnosticPublishDelay": 0,
  // OCaml
  "ocaml.terminal.shell.osx": "/bin/zsh",
  "[ocaml]": {
    "editor.defaultFormatter": "ocamllabs.ocaml-platform"
  },
  "ocaml.sandbox": {
    "switch": "default",
    "kind": "opam"
  },
  // Dart
  "dart.openDevTools": "flutter",
  // HTML & CSS
  "css.styleSheets": [
    "https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css",
    "/style.css",
    "style.css",
    "${fileBasenameNoExtension}.css"
  ],
  // Javascript/Typescript
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  // Sonar Lint
  "sonarlint.rules": {
    "java:S106": {
      "level": "off"
    },
    "java:S2189": {
      "level": "off"
    },
    "java:S1192": {
      "level": "off"
    }
  },
  // Markdown
  "markdown.preview.fontFamily": "JetBrains Mono, monospace",
  "markdown.preview.fontSize": 14,
  // LaTeX
  "latex.build.executable": "latexmk",
  "latex.build.args": [
    "-f",
    "-pdf",
    "-interaction=nonstopmode",
    "-synctex=1",
    "%f"
  ],
  "latex.lint.onChange": true,
  "latex.lint.onSave": true,
  // Spell Check
  "cSpell.language": "en,pt",
  "cSpell.userWords": [
    "rebalance"
  ],
  // PDF
  "pdf-preview.default.scale": "page-fit",
  // liveshare
  "liveshare.presence": true,
  "liveshare.audio.joinCallBehavior": "accept",
  "liveshare.audio.startCallOnShare": true,
  // Extensions
  "extensions.ignoreRecommendations": true,
  "workbench.editorAssociations": [
    {
      "viewType": "jupyter.notebook.ipynb",
      "filenamePattern": "*.ipynb"
    }
  ],
}
