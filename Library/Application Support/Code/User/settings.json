{
  // Window
  "window.title": "${appName}${separator}${activeEditorShort}${separator}${rootName}",
  "window.autoDetectColorScheme": true,
  "window.restoreFullscreen": true,
  "window.zoomLevel": 0,
  // Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  // Files
  "files.simpleDialog.enable": true,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.enableTrash": true,
  "files.associations": {
    "*.cu": "cpp",
    "*.cuh": "cpp"
  },
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "**/__pycache__": true,
    "**/node_modules": true
  },
  // Workbench
  "workbench.startupEditor": "none",
  "workbench.commandPalette.history": 0,
  "workbench.editor.restoreViewState": true,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.list.automaticKeyboardNavigation": false,
  "workbench.settings.openDefaultSettings": false,
  "workbench.settings.editor": "json",
  "breadcrumbs.enabled": false,
  // Theme
  "workbench.colorTheme": "Ayu Dark Bordered",
  "workbench.preferredLightColorTheme": "Ayu Light Bordered",
  "workbench.preferredDarkColorTheme": "Ayu Dark Bordered",
  "workbench.iconTheme": "ayu",
  // Neovim
  "vscode-neovim.neovimExecutablePaths.darwin": "/usr/local/bin/nvim",
  // Editor
  "editor.fontFamily": "JetBrains Mono, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.wrappingIndent": "deepIndent",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.tabCompletion": "on",
  "editor.acceptSuggestionOnEnter": "off",
  // Suggestions
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.snippetSuggestions": "top",
  "editor.wordBasedSuggestions": false,
  "editor.quickSuggestionsDelay": 0,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  // Visual
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.selectionHighlight": false,
  "editor.occurrencesHighlight": false,
  "editor.renderLineHighlight": "none",
  "editor.renderWhitespace": "none",
  "editor.renderIndentGuides": false,
  "editor.cursorSmoothCaretAnimation": true,
  "editor.scrollBeyondLastLine": false,
  "editor.smoothScrolling": true,
  "editor.rulers": [
    {
      "column": 80,
      "color": "#2979FF40"
    },
    {
      "column": 120,
      "color": "#2979FF40"
    }
  ],
  // source
  "editor.codeActionsOnSave": {
    "source.organizeImports": true,
    "source.fixAll": true
  },
  // Debug
  "debug.console.fontFamily": "JetBrains Mono, monospace",
  "debug.inlineValues": true,
  // Terminal
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontFamily": "JetBrains Mono, monospace",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.showExitAlert": false,
  // Git
  "diffEditor.ignoreTrimWhitespace": false,
  "git.postCommitCommand": "sync",
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  // C
  "C_Cpp.clang_format_fallbackStyle": "Google",
  "C_Cpp.clang_format_sortIncludes": false,
  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.default.cStandard": "c11",
  // Java
  "java.semanticHighlighting.enabled": true,
  "java.referencesCodeLens.enabled": true,
  "java.implementationsCodeLens.enabled": true,
  "java.codeGeneration.generateComments": true,
  "java.completion.guessMethodArguments": true,
  "java.format.comments.enabled": true,
  // Python
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "/usr/local/bin/python3",
  "python.formatting.provider": "autopep8",
  "python.analysis.diagnosticPublishDelay": 0,
  "python.linting.pylintUseMinimalCheckers": false,
  "python.testing.pytestArgs": [],
  "python.testing.unittestEnabled": false,
  "python.testing.nosetestsEnabled": false,
  "python.testing.pytestEnabled": true,
  "python.dataScience.sendSelectionToInteractiveWindow": true,
  // OCaml
  "ocaml.sandbox": {
    "switch": "default",
    "kind": "opam"
  },
  // Dart
  "dart.openDevTools": "flutter",
  // HTML & CSS
  "css.remoteStyleSheets": [
    "https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css"
  ],
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Javascript/Typescript
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.implicitProjectConfig.checkJs": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "tslint.jsEnable": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Json
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Markdown
  "markdown.preview.fontFamily": "JetBrains Mono, monospace",
  // Extensions
  "extensions.ignoreRecommendations": true,
  "liveshare.presence": true
}
